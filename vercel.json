{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cqc-alerts",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/cqc-alerts",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cqc-alerts",
      "schedule": "0 6 * * *"
    }
  ]
}
